{
  "name": "ts-video-player",
  "type": "module",
  "version": "0.1.0",
  "description": "A modern, framework-agnostic video player with deep stx integration",
  "author": "Chris Breuer <chris@stacksjs.org>",
  "license": "MIT",
  "homepage": "https://github.com/stacksjs/ts-video-player#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stacksjs/ts-video-player.git"
  },
  "bugs": {
    "url": "https://github.com/stacksjs/ts-video-player/issues"
  },
  "keywords": [
    "video",
    "player",
    "media",
    "hls",
    "dash",
    "youtube",
    "vimeo",
    "stx",
    "web-components",
    "accessibility",
    "streaming",
    "captions",
    "subtitles",
    "ads",
    "vast",
    "analytics"
  ],
  "scripts": {
    "build": "bun run --filter './packages/*' build",
    "dev": "bun run --filter ts-video-player dev",
    "fresh": "bunx rimraf node_modules/ bun.lock && bun i",
    "test": "bun test",
    "lint": "bunx --bun pickier .",
    "lint:fix": "bunx --bun pickier . --fix",
    "changelog": "bunx logsmith --verbose",
    "changelog:generate": "bunx logsmith --output CHANGELOG.md",
    "release": "bun --bun run changelog:generate && bunx --bun bumpx prompt --recursive",
    "dev:docs": "bunx bunpress dev",
    "build:docs": "bunx bunpress build",
    "preview:docs": "bunx bunpress preview",
    "typecheck": "bun --bun tsc --noEmit",
    "format": "bunx --bun pickier . --format",
    "format:fix": "bunx --bun pickier . --format --write",
    "postinstall": "bunx git-hooks"
  },
  "devDependencies": {
    "@stacksjs/clapp": "^0.2.0",
    "better-dx": "^0.2.7",
    "bun-git-hooks": "^0.3.1"
  },
  "git-hooks": {
    "pre-commit": {
      "stagedLint": {
        "*.{js,ts,json,yaml,yml,md}": "bunx --bun pickier lint --fix"
      }
    },
    "commit-msg": "bunx --bun @stacksjs/gitlint --edit .git/COMMIT_EDITMSG"
  }
}
